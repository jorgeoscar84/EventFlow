# ╔══════════════════════════════════════════════════════════════════╗
# ║  Eventflow — Variables de entorno                               ║
# ║  Copia este archivo como .env y completa los valores.           ║
# ║  En Vercel: configura cada variable en el dashboard de tu proyecto.║
# ╚══════════════════════════════════════════════════════════════════╝

# ───────── App ─────────
APP_BASE_URL=http://localhost:3000
# En Vercel, Vercel lo inyecta automáticamente como VERCEL_URL, pero
# debes crear APP_BASE_URL = https://tu-dominio.vercel.app (o tu dominio)
NODE_ENV=development
ROOT_DOMAIN=eventflow.app

# ───────── Base de datos (Supabase Postgres — pooler IPv4) ─────────
# Transaction pooler (puerto 6543) para la app:
DATABASE_URL=postgresql://postgres.REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
# Session pooler (puerto 5432) para migraciones:
DIRECT_URL=postgresql://postgres.REF:PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres

# ───────── Supabase ─────────
SUPABASE_URL=https://REF.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ───────── Auth (genera con: node -e "console.log(require('crypto').randomBytes(36).toString('base64'))") ─────────
AUTH_SECRET=genera-un-string-aleatorio-largo-aqui

# ───────── Vercel Cron (seguridad del endpoint /api/cron/scheduler) ─────────
# Genera con: openssl rand -hex 32  |  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=genera-un-string-aleatorio-aqui

# ───────── Email (Amazon SES SMTP) ─────────
# Obtener en: AWS Console → SES → SMTP Settings → "Create SMTP credentials"
# IMPORTANTE: verificar dominio + DKIM/SPF; salir del sandbox de SES
SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SES_SMTP_PORT=587
SES_SMTP_USER=
SES_SMTP_PASS=
SES_REGION=us-east-1
MAIL_FROM_DEFAULT="Eventflow <no-reply@tu-dominio.com>"

# ───────── Pagos (Stripe) ─────────
# Dashboard Stripe → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ───────── WhatsApp / Twilio (fase posterior) ─────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
WHATSAPP_PROVIDER=none

# ───────── LLM (configurable también desde el panel /dashboard/settings) ─────────
# Las variables de aquí son el fallback de plataforma.
# Cada tenant puede configurar su propio proveedor desde el panel.
# Compatible con cualquier API OpenAI: OpenRouter, OpenAI, Groq, Azure, Ollama...
LLM_PLATFORM_BASE_URL=https://openrouter.ai/api/v1
LLM_PLATFORM_API_KEY=
LLM_PLATFORM_MODEL=openai/gpt-4o-mini

# ───────── Observabilidad ─────────
SENTRY_DSN=
