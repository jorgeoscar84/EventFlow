# ───────── App ─────────
APP_BASE_URL=http://localhost:3000
NODE_ENV=development

# ───────── Base de datos (Postgres / Supabase) ─────────
DATABASE_URL=postgresql://user:pass@localhost:5432/eventflow?schema=public
DIRECT_URL=postgresql://user:pass@localhost:5432/eventflow?schema=public

# ───────── Supabase ─────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ───────── Auth ─────────
AUTH_SECRET=changeme-generate-a-long-random-string

# ───────── Email (Amazon SES SMTP) ─────────
SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SES_SMTP_PORT=587
SES_SMTP_USER=
SES_SMTP_PASS=
SES_REGION=us-east-1
MAIL_FROM_DEFAULT="Eventflow <no-reply@example.com>"

# ───────── Redis / Jobs (BullMQ) ─────────
REDIS_URL=redis://localhost:6379

# ───────── Pagos (Stripe) ─────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ───────── WhatsApp / Twilio (estructura, fase posterior) ─────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
WHATSAPP_PROVIDER=none

# ───────── IA / LLM (asistente M14) ─────────
LLM_PROVIDER_DEFAULT=openai
LLM_API_KEY=
LLM_MODEL_DEFAULT=
EMBEDDINGS_MODEL=

# ───────── Observabilidad ─────────
SENTRY_DSN=
